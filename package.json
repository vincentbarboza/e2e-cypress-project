  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "cypress": "^15.14.0",
    "eslint": "^10.2.1",
    "eslint-plugin-cypress": "^6.3.1",
    "eslint-plugin-mocha": "^11.2.0",
    "globals": "^17.5.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2"
